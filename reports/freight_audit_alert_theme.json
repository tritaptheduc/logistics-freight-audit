{
  "name": "Freight Audit Enterprise Premium",
  "dataColors": [
    "#1E3A8A",
    "#F97316",
    "#3B82F6",
    "#A855F7",
    "#10B981",
    "#64748B"
  ],
  "background": "#F8FAFC",
  "foreground": "#0F172A",
  "tableAccent": "#0F172A",
  "visualStyles": {
    "*": {
      "*": {
        "outspacePane": [{ "backgroundColor": { "solid": { "color": "#F8FAFC" } } }],
        "background": [{ "show": true, "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 0 }],
        "border": [{ "show": true, "color": { "solid": { "color": "#E2E8F0" } }, "radius": 6 }],
        "dropShadow": [{ "show": true, "color": { "solid": { "color": "#000000" } }, "position": "Outer", "preset": "BottomRight", "transparency": 96 }],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#0F172A" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI Bold",
            "alignment": "Left"
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#0F172A" } },
            "fontSize": 18,
            "fontFamily": "Segoe UI Bold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#475569" } },
            "fontSize": 9,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "multiRowCard": {
      "*": {
        "dataLabels": [{ "fontSize": 18, "fontFamily": "Segoe UI Bold", "color": { "solid": { "color": "#0F172A" } } }],
        "categoryLabels": [{ "fontSize": 9, "fontFamily": "Segoe UI Semibold", "color": { "solid": { "color": "#475569" } } }]
      }
    },
    "slicer": {
      "*": {
        "header": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#0F172A" } },
            "fontSize": 9.5,
            "fontFamily": "Segoe UI Bold"
          }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#334155" } },
            "background": { "solid": { "color": "#FFFFFF" } },
            "fontSize": 9
          }
        ]
      }
    },
    "barChart": {
      "*": {
        "categoryAxis": [
          {
            "show": true,
            "labelColor": { "solid": { "color": "#475569" } },
            "fontSize": 9,
            "fontFamily": "Segoe UI"
          }
        ],
        "valueAxis": [
          {
            "show": false
          }
        ],
        "labels": [
          {
            "show": true,
            "color": { "solid": { "color": "#1E293B" } },
            "fontSize": 8.5,
            "fontFamily": "Segoe UI Bold"
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": { "solid": { "color": "#E2E8F0" } },
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#E2E8F0" } },
            "rowPadding": 4
          }
        ],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "backColor": { "solid": { "color": "#0F172A" } },
            "fontSize": 9.5,
            "fontFamily": "Segoe UI Bold",
            "alignment": "Left"
          }
        ],
        "values": [
          {
            "fontColorPrimary": { "solid": { "color": "#0F172A" } },
            "backColorPrimary": { "solid": { "color": "#FFFFFF" } },
            "fontColorSecondary": { "solid": { "color": "#0F172A" } },
            "backColorSecondary": { "solid": { "color": "#F8FAFC" } },
            "fontSize": 9,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    }
  }
}